<ResourceDictionary
    x:Class="NoxAeterna.App.Themes.DarkThemeResources"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <SolidColorBrush x:Key="ShellWindowBackgroundBrush" Color="#0E0E11" />
  <SolidColorBrush x:Key="ShellNavigationPanelBackgroundBrush" Color="#17171A" />
  <SolidColorBrush x:Key="ShellContentPanelBackgroundBrush" Color="#121214" />
  <SolidColorBrush x:Key="ShellPanelBorderBrush" Color="#34343A" />
  <SolidColorBrush x:Key="ShellSecondaryForegroundBrush" Color="#A8A8AF" />
  <SolidColorBrush x:Key="WorkspacePanelBackgroundBrush" Color="#17171B" />
  <SolidColorBrush x:Key="WorkspacePanelBorderBrush" Color="#35353D" />
  <SolidColorBrush x:Key="WorkspacePanelSubtleForegroundBrush" Color="#9999A3" />
  <SolidColorBrush x:Key="WorkspaceValidationErrorBrush" Color="#D08B8B" />
  <SolidColorBrush x:Key="WorkspaceValidationSuccessBrush" Color="#93B38B" />
  <SolidColorBrush x:Key="PreviewSurfaceBackgroundBrush" Color="#131317" />
  <SolidColorBrush x:Key="PreviewSurfaceBorderBrush" Color="#4A4A52" />
</ResourceDictionary>

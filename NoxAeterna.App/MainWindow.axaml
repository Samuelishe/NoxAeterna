<Window
    x:Class="NoxAeterna.App.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Nox Aeterna"
    Background="{DynamicResource ShellWindowBackgroundBrush}"
    Width="1280"
    Height="800">
  <Grid ColumnDefinitions="240,*" Margin="20">
    <Border Grid.Column="0"
            Padding="16"
            Background="{DynamicResource ShellNavigationPanelBackgroundBrush}"
            BorderBrush="{DynamicResource ShellPanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="6">
      <StackPanel Spacing="12">
        <TextBlock x:Name="NavigationTitleTextBlock"
                   FontSize="16"
                   FontWeight="SemiBold" />
        <ListBox x:Name="NavigationListBox"
                 SelectionChanged="OnNavigationSelectionChanged" />
      </StackPanel>
    </Border>

    <Border Grid.Column="1"
            Margin="16,0,0,0"
            Padding="16"
            Background="{DynamicResource ShellContentPanelBackgroundBrush}"
            BorderBrush="{DynamicResource ShellPanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="6">
      <Grid RowDefinitions="Auto,Auto,*">
        <TextBlock x:Name="SectionTitleTextBlock"
                   FontSize="20"
                   FontWeight="SemiBold" />
        <TextBlock x:Name="SectionHintTextBlock"
                   Grid.Row="1"
                   Margin="0,6,0,0"
                   Foreground="{DynamicResource ShellSecondaryForegroundBrush}" />
        <ContentControl x:Name="SectionContentHost"
                        Grid.Row="2"
                        Margin="0,16,0,0" />
      </Grid>
    </Border>
  </Grid>
</Window>
